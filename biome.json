{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist/**",
      "!**/build/**",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/.next/**",
      "!**/.worktrees/**",
      "!**/.astro/**",
      "!**/*.astro",
      "!**/*.css",
      "!oracle/test/integration/**",
      "!docs/hackathon/_*-head.html"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": {
          "level": "error",
          "options": { "ignoreRestSiblings": true }
        },
        "noUnusedPrivateClassMembers": "error",
        "noUnreachable": "error",
        "noConstantCondition": "error",
        "noConstantMathMinMaxClamp": "error",
        "noInvalidUseBeforeDeclaration": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noDebugger": "error",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["warn", "error"] }
        },
        "noEmptyBlockStatements": "warn",
        "noDoubleEquals": "error",
        "noSelfCompare": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noFallthroughSwitchClause": "error",
        "noVar": "error"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useShorthandAssign": "error",
        "useConsistentArrayType": {
          "level": "error",
          "options": { "syntax": "shorthand" }
        },
        "useConsistentBuiltinInstantiation": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useNodejsImportProtocol": "error",
        "useThrowOnlyError": "error",
        "noNonNullAssertion": "warn",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "lodash": "Use native JS or lodash-es.",
              "moment": "Use date-fns or Temporal.",
              "axios": "Use fetch."
            }
          }
        }
      },
      "complexity": {
        "useOptionalChain": "error",
        "noUselessTypeConstraint": "error",
        "noUselessConstructor": "error",
        "noUselessRename": "error",
        "noUselessTernary": "error",
        "noBannedTypes": "error"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "performance": {
        "noDelete": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.{test,spec}.{ts,tsx}",
        "**/tests/**/*.{ts,tsx}",
        "**/__tests__/**/*.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "performance": { "noDelete": "off" },
          "suspicious": {
            "noEmptyBlockStatements": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/scripts/**/*.{ts,tsx,js,mjs}",
        "auth/src/index.ts",
        "oracle/src/index.ts",
        "oracle/src/shared/logger.ts",
        "oracle/src/providers/registry.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" }
        }
      }
    }
  ]
}
