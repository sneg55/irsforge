module Oracle.Test where

import Daml.Script
import DA.Date (date, Month(..))
import DA.List (head)
import DA.Time (time)
import Daml.Finance.Interface.Types.Common.V3.Types (Id(..))
import Oracle.DemoStubProvider (DemoStubOracleProvider(..))
import Oracle.FloatingRateIndex (FloatingRateIndex(..))
import Oracle.Interface
import Oracle.Interpolation (interpolateZero, computeDF)
import Oracle.NYFedProvider
import Oracle.Types
import Setup.GeneratedRateFamilies

oraclePublishTest : Script ()
oraclePublishTest = do
  operator <- allocatePartyWithHint "Operator" (PartyIdHint "Operator")
  partyA <- allocatePartyWithHint "PartyA" (PartyIdHint "PartyA")

  providerCid <- submit operator do
    createCmd NYFedOracleProvider with
      operator
      subscribers = [partyA]
      regulators = [operator]
      supportedRateIds = [sofrIndexRateId]

  obsCid <- submit operator do
    exerciseCmd (toInterfaceContractId @Provider providerCid) Provider_PublishRate with
      args = PublishRateArgs with
        rateId = sofrIndexRateId
        effectiveDate = date 2026 Apr 16
        value = 1.23873374

  obs <- queryContractId operator obsCid
  case obs of
    None -> abort "Observation not found"
    Some o -> do
      assertMsg "Provider should be operator" (o.provider == operator)
      assertMsg "Rate ID should match" (o.id == Id sofrIndexRateId)

  pure ()

