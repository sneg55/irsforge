floatingRateIndexRegistryTest : Script ()
floatingRateIndexRegistryTest = do
  operator <- allocatePartyWithHint "Operator" (PartyIdHint "Operator")
  regulator <- allocatePartyWithHint "Regulator" (PartyIdHint "Regulator")

  indexCid <- submit operator do
    createCmd FloatingRateIndex with
      operator
      subscribers = []
      regulators = [regulator]
      indexId = "USD-SOFR"
      currency = "USD"
      family = SOFR
      compounding = CompoundedInArrears
      lookback = 2
      floor = Some 0.0

  idx <- queryContractId operator indexCid
  case idx of
    None -> abort "FloatingRateIndex not found"
    Some i -> do
      assertMsg "Family SOFR" (i.family == SOFR)
      assertMsg "Lookback 2" (i.lookback == 2)

  pure ()
