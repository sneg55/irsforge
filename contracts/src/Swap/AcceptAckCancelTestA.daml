      notional = 25_000_000.0; currency = "USD"
      leg0Spread = 0.0; leg1Spread = 0.0025
      startDate = date 2026 Apr 16; maturityDate = date 2031 Apr 16
      dayCountConvention = Act360
  ackCid <- submit tp.partyB do
    exerciseCmd proposalCid BasisProposeAccept with
      operator = tp.operator; regulators = [tp.regulator]
      leg0FloatingRateIndexCid = sofrCid
      leg1FloatingRateIndexCid = effrCid
  submit tp.operator do
    exerciseCmd ackCid BasisAcceptAckCancelByOperator
