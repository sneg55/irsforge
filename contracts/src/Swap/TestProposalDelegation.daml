-- Tests for `Swap.ProposalDelegation`. The delegation lets traders create
-- swap proposals with only their own party authority — the production-OIDC
-- gap that Bug 1 (2026-04-28 audit) called out.
module Swap.TestProposalDelegation where

import Daml.Script
import DA.Date (date, Month(..))
import Daml.Finance.Interface.Types.Date.V3.DayCount (DayCountConventionEnum(..))
import Swap.Proposal (SwapProposal(..))
import Swap.OisProposal (OisProposal(..))
import Swap.BasisSwapProposal (BasisSwapProposal(..))
import Swap.XccyFixedFloatProposal (XccyFixedFloatProposal(..))
import Swap.CdsProposal (CdsProposal(..))
import Swap.CcySwapProposal (CcySwapProposal(..))
import Swap.FxSwapProposal (FxSwapProposal(..))
import Swap.AssetSwapProposal (AssetSwapProposal(..))
import Swap.FpmlProposal (FpmlProposal(..))
import Swap.ProposalDelegation
  ( ProposalDelegation(..)
  , CreateSwapProposal(..)
  , CreateOisProposal(..)
  , CreateBasisSwapProposal(..)
  , CreateXccyFixedFloatProposal(..)
  , CreateCdsProposal(..)
  , CreateCcySwapProposal(..)
  , CreateFxSwapProposal(..)
  , CreateAssetSwapProposal(..)
  , CreateFpmlProposal(..)
  )
import Swap.Types (TenorEnum(..), FpmlLeg(..))
import Swap.TestHelpers

-- | Bug 1 regression: a trader with single-party authority (no operator
--   actAs) creates an IRS proposal via the delegation. The resulting
--   SwapProposal still has signatory {proposer, operator} so existing
--   Accept paths are unchanged.
proposerOnlyCreateViaDelegation : Script ()
proposerOnlyCreateViaDelegation = do
  tp <- allocateTestParties

  delegationCid <- submit tp.operator do
    createCmd ProposalDelegation with
      operator = tp.operator
      traders  = [tp.partyA, tp.partyB]

  _proposalCid <- submit tp.partyA do
    exerciseCmd delegationCid CreateSwapProposal with
      proposer           = tp.partyA
      counterparty       = tp.partyB
      notional           = 10_000_000.0
      fixRate            = 0.0485
      tenor              = D90
      startDate          = date 2026 Apr 16
      dayCountConvention = Act360

  proposals <- query @SwapProposal tp.partyB
  assertMsg "PartyB sees 1 proposal created via delegation"
    (length proposals == 1)
  case proposals of
    ((_, p) :: _) ->
      assertMsg "delegated-created proposal still names operator"
        (p.operator == tp.operator)
    [] -> error "unreachable: length-1 list is non-empty"

-- | A party not in the delegation whitelist cannot use it.
delegationRejectsNonWhitelistedProposer : Script ()
delegationRejectsNonWhitelistedProposer = do
  tp <- allocateTestParties
  outsider <- allocatePartyWithHint "Outsider" (PartyIdHint "outsider")

  delegationCid <- submit tp.operator do
    createCmd ProposalDelegation with
      operator = tp.operator
      traders  = [tp.partyA, tp.partyB]

  submitMustFail outsider do
    exerciseCmd delegationCid CreateSwapProposal with
      proposer           = outsider
      counterparty       = tp.partyB
      notional           = 10_000_000.0
      fixRate            = 0.0485
      tenor              = D90
      startDate          = date 2026 Apr 16
      dayCountConvention = Act360

-- Helper: stand up a delegation contract for the standard test pair.
mkDelegation : TestParties -> Script (ContractId ProposalDelegation)
mkDelegation tp = submit tp.operator do
  createCmd ProposalDelegation with
    operator = tp.operator
    traders  = [tp.partyA, tp.partyB]

-- Per-family proposer-only smoke tests. Each demonstrates that a
-- single-party `submit proposer` is sufficient to create a proposal of
-- that family via the delegation, and that the resulting contract still
-- carries operator as a signatory (so existing Accept paths are
-- unchanged).

oisProposerOnly : Script ()
oisProposerOnly = do
  tp <- allocateTestParties
  d <- mkDelegation tp
  _ <- submit tp.partyA do
    exerciseCmd d CreateOisProposal with
      proposer            = tp.partyA
      counterparty        = tp.partyB
      notional            = 10_000_000.0
      fixRate             = 0.04
      startDate           = date 2026 Apr 16
      maturityDate        = date 2027 Apr 16
      dayCountConvention  = Act360
  ps <- query @OisProposal tp.partyB
  assertMsg "OIS proposal created" (length ps == 1)

basisProposerOnly : Script ()
basisProposerOnly = do
  tp <- allocateTestParties
  d <- mkDelegation tp
  _ <- submit tp.partyA do
    exerciseCmd d CreateBasisSwapProposal with
      proposer            = tp.partyA
      counterparty        = tp.partyB
      notional            = 10_000_000.0
      currency            = "USD"
      leg0Spread          = 0.001
      leg1Spread          = 0.002
      startDate           = date 2026 Apr 16
      maturityDate        = date 2027 Apr 16
      dayCountConvention  = Act360
  ps <- query @BasisSwapProposal tp.partyB
  assertMsg "Basis proposal created" (length ps == 1)

