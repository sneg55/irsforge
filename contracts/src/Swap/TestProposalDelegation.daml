fpmlProposerOnly : Script ()
fpmlProposerOnly = do
  tp <- allocateTestParties
  d <- mkDelegation tp
  let fixedLeg = FpmlLeg with
        legType = "fixed"
        currency = "USD"
        notional = 10_000_000.0
        rate = Some 0.04
        indexId = None
        spread = None
        dayCountConvention = Act360
  _ <- submit tp.partyA do
    exerciseCmd d CreateFpmlProposal with
      proposer     = tp.partyA
      counterparty = tp.partyB
      legs         = [fixedLeg]
      startDate    = date 2026 Apr 16
      maturityDate = date 2027 Apr 16
      description  = "demo FpML"
  ps <- query @FpmlProposal tp.partyB
  assertMsg "FpML proposal created" (length ps == 1)
