testFxAcceptAckCancelByCounterparty : Script ()
testFxAcceptAckCancelByCounterparty = do
  tp <- allocateTestParties
  runInit tp
  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd FxSwapProposal with
      operator = tp.operator; proposer = tp.partyA; counterparty = tp.partyB
      notional = 10_000_000.0; baseCurrency = "USD"; foreignCurrency = "EUR"
      firstFxRate = 1.08; finalFxRate = 1.085
      firstPaymentDate = date 2026 Jul 16; maturityDate = date 2027 Apr 16
  ackCid <- submit tp.partyB do
    exerciseCmd proposalCid FxProposeAccept with
      operator = tp.operator; regulators = [tp.regulator]
  submit tp.partyB do
    exerciseCmd ackCid FxAcceptAckCancelByCounterparty
  acks <- query @FxAcceptAck tp.operator
  assertMsg "FxAcceptAck must be archived" (null acks)

