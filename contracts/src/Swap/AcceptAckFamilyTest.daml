testFxProposeAcceptHappyPath : Script ()
testFxProposeAcceptHappyPath = do
  tp <- allocateTestParties
  runInit tp
  let firstPaymentDate = date 2026 Jul 16
  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd FxSwapProposal with
      operator = tp.operator; proposer = tp.partyA; counterparty = tp.partyB
      notional = 10_000_000.0; baseCurrency = "USD"; foreignCurrency = "EUR"
      firstFxRate = 1.08; finalFxRate = 1.085
      firstPaymentDate; maturityDate = date 2027 Apr 16
  ackCid <- submit tp.partyB do
    exerciseCmd proposalCid FxProposeAccept with
      operator = tp.operator; regulators = [tp.regulator]
  _ <- submit tp.operator do exerciseCmd ackCid FxConfirmAccept
  workflows <- query @SwapWorkflow tp.partyA
  assertMsg "Should have 1 FX SwapWorkflow" (length workflows == 1)
  case workflows of
    [(_, wf)] -> assertMsg "swapType FX" (wf.swapType == "FX")
    _ -> assertFail "Expected 1 workflow"
  debug "testFxProposeAcceptHappyPath passed"

testAssetProposeAcceptHappyPath : Script ()
testAssetProposeAcceptHappyPath = do
  tp <- allocateTestParties
  runInit tp
  fridCid <- seedUsdSofrIndex tp
  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd AssetSwapProposal with
      operator = tp.operator; proposer = tp.partyA; counterparty = tp.partyB
      notional = 10_000_000.0; fixRate = 0.03; ownerReceivesRate = True
      underlyingAssetIds = ["UST-10Y"]; underlyingWeights = [1.0]
      startDate = date 2026 Apr 16; maturityDate = date 2027 Apr 16
      dayCountConvention = Act360
  ackCid <- submit tp.partyB do
    exerciseCmd proposalCid AssetProposeAccept with
      operator = tp.operator; regulators = [tp.regulator]
      floatingRateIndexCid = fridCid
  _ <- submit tp.operator do exerciseCmd ackCid AssetConfirmAccept
  workflows <- query @SwapWorkflow tp.partyA
  assertMsg "Should have 1 ASSET SwapWorkflow" (length workflows == 1)
  case workflows of
    [(_, wf)] -> assertMsg "swapType ASSET" (wf.swapType == "ASSET")
    _ -> assertFail "Expected 1 workflow"
  debug "testAssetProposeAcceptHappyPath passed"

testFpmlProposeAcceptHappyPath : Script ()
testFpmlProposeAcceptHappyPath = do
  tp <- allocateTestParties
  runInit tp
  let
    fixedLeg = FpmlLeg with
      legType = "fixed"; currency = "USD"; notional = 25_000_000.0
      rate = Some 0.0485; indexId = None; spread = None
      dayCountConvention = Act360
    floatLeg = FpmlLeg with
      legType = "float"; currency = "USD"; notional = 25_000_000.0
      rate = None; indexId = Some "USD-SOFR"; spread = Some 0.0
      dayCountConvention = Act360
  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd FpmlProposal with
      operator = tp.operator; proposer = tp.partyA; counterparty = tp.partyB
      legs = [fixedLeg, floatLeg]
      startDate = date 2026 Apr 16; maturityDate = date 2027 Apr 16
      description = "FpML test swap"
  ackCid <- submit tp.partyB do
    exerciseCmd proposalCid FpmlProposeAccept with
      operator = tp.operator; regulators = [tp.regulator]
  _ <- submit tp.operator do exerciseCmd ackCid FpmlConfirmAccept
  workflows <- query @SwapWorkflow tp.partyA
  assertMsg "Should have 1 FpML SwapWorkflow" (length workflows == 1)
  case workflows of
    [(_, wf)] -> assertMsg "swapType FpML" (wf.swapType == "FpML")
    _ -> assertFail "Expected 1 workflow"
  debug "testFpmlProposeAcceptHappyPath passed"
