-- Tests for CDS, CCY, FX, Asset, and FpML swap proposals
module Swap.TestAltSwaps where

import Daml.Script
import DA.Date (date, Month(..))
import Daml.Finance.Interface.Types.Date.V3.DayCount (DayCountConventionEnum(..))
import qualified Daml.Finance.Instrument.Swap.V0.Fpml.Instrument
import Swap.CdsProposal
import Swap.CcySwapProposal
import Swap.FxSwapProposal
import Swap.AssetSwapProposal
import Swap.FpmlProposal
import Swap.Types (FpmlLeg(..))
import Swap.Workflow
import Swap.TestHelpers
import Setup.GeneratedRateFamilies

-- ---------------------------------------------------------------------------
-- CDS
-- ---------------------------------------------------------------------------

-- | Create CDS proposal then accept; verify SwapWorkflow fields
cdsAcceptTest : Script ()
cdsAcceptTest = do
  tp <- allocateTestParties
  runInit tp

  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd CdsProposal with
      operator = tp.operator
      proposer = tp.partyA
      counterparty = tp.partyB
      notional = 5_000_000.0
      fixRate = 0.015
      referenceName = "TSLA"
      ownerReceivesFix = True
      startDate = date 2026 Apr 16
      maturityDate = date 2027 Apr 16
      dayCountConvention = Act360

  _workflowCid <- submit tp.partyB do
    exerciseCmd proposalCid CdsAccept with
      operator = tp.operator
      regulators = [tp.regulator]
  workflows <- query @SwapWorkflow tp.partyA
  assertMsg "Should have 1 CDS workflow" (length workflows == 1)

  case workflows of
    [(_, wf)] -> do
      assertMsg "swapType CDS"     (wf.swapType == "CDS")
      assertMsg "notional 5M"      (wf.notional == 5_000_000.0)
    _ -> assertFail "Expected exactly 1 workflow"

  debug "cdsAcceptTest passed"
  pure ()

-- | Create CDS proposal then reject; no proposals should remain
cdsRejectTest : Script ()
cdsRejectTest = do
  tp <- allocateTestParties

  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd CdsProposal with
      operator = tp.operator
      proposer = tp.partyA
      counterparty = tp.partyB
      notional = 5_000_000.0
      fixRate = 0.015
      referenceName = "TSLA"
      ownerReceivesFix = True
      startDate = date 2026 Apr 16
      maturityDate = date 2027 Apr 16
      dayCountConvention = Act360

  submit tp.partyB do
    exerciseCmd proposalCid CdsReject

  proposals <- query @CdsProposal tp.partyB
  assertMsg "No CDS proposals should remain after reject" (null proposals)
  pure ()

