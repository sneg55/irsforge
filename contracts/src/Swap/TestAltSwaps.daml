-- | Create CCY swap proposal then accept; verify SwapWorkflow fields
ccyAcceptTest : Script ()
ccyAcceptTest = do
  tp <- allocateTestParties
  runInit tp

  proposalCid <- submitMulti [tp.partyA, tp.operator] [] do
    createCmd CcySwapProposal with
      operator = tp.operator
      proposer = tp.partyA
      counterparty = tp.partyB
      notional = 10_000_000.0
      baseRate = 0.03
      foreignRate = 0.025
      baseCurrency = "USD"
      foreignCurrency = "EUR"
      fxRate = 1.08
      ownerReceivesBase = True
      startDate = date 2026 Apr 16
      maturityDate = date 2027 Apr 16
      dayCountConvention = Act360

  _workflowCid <- submit tp.partyB do
    exerciseCmd proposalCid CcyAccept with
      operator = tp.operator
      regulators = [tp.regulator]
  workflows <- query @SwapWorkflow tp.partyA
  assertMsg "Should have 1 CCY workflow" (length workflows == 1)

  case workflows of
    [(_, wf)] -> do
      assertMsg "swapType CCY"  (wf.swapType == "CCY")
    _ -> assertFail "Expected exactly 1 workflow"

  debug "ccyAcceptTest passed"
  pure ()

