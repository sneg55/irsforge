---
---
<footer class="footer">
  <div class="cols">
    <div class="col">
      <div class="brand-wrap">
        <img src="/favicon.svg" alt="" width="56" height="56" class="footer-mark" />
        <div class="brand">IRSForge</div>
      </div>
      <p class="muted">Open-source rates infrastructure for Canton Network.</p>
    </div>
    <div class="col">
      <h2>Product</h2>
      <a href="https://demo.irsforge.com">Live Demo</a>
      <a href="https://docs.irsforge.com">Docs</a>
      <a href="https://github.com/sneg55/irsforge">GitHub</a>
    </div>
    <div class="col">
      <h2>Resources</h2>
      <a href="https://docs.irsforge.com/getting-started/quickstart">Quickstart</a>
      <a href="#faq">FAQ</a>
      <a href="https://docs.irsforge.com/reference/config-yaml">Reference</a>
    </div>
    <div class="col">
      <h2>Connect</h2>
      <a href="https://cal.com/sawinyh/irsforge-demo">Book a Call</a>
      <a href="https://github.com/sneg55/irsforge/issues">Issues</a>
    </div>
  </div>
  <div class="bottom">© 2026 IRSForge · AGPL v3.0</div>
</footer>

<style>
  .footer { padding: 4rem 2rem 2rem; border-top: 1px solid var(--color-border); }
  .cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .col { display: flex; flex-direction: column; gap: 0.5rem; }
  /* h2 used (not h4) so heading order stays h1 -> h2 -> h3 across the page (lhci heading-order gate) */
  .col h2 { font-family: var(--font-body); font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-fg-muted); font-weight: 500; margin: 0 0 0.5rem; }
  .col a {
    align-self: flex-start;
    background-image: linear-gradient(var(--color-fg), var(--color-fg));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: color .2s ease, background-size .3s cubic-bezier(.2,.7,.2,1);
  }
  .col a:hover { background-size: 100% 1px; }
  .brand { font-family: var(--font-display); font-size: 1.75rem; color: var(--color-fg); }
  .brand-wrap { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; }
  .footer-mark {
    border-radius: 5px;
    display: block;
    transition: transform .35s cubic-bezier(.2,.7,.2,1), filter .35s ease;
  }
  .brand-wrap:hover .footer-mark {
    transform: rotate(-6deg) scale(1.04);
    filter: drop-shadow(0 6px 16px rgba(201, 169, 97, 0.3));
  }
  .muted { color: var(--color-fg-muted); font-size: 0.875rem; }
  .bottom { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); text-align: center; color: var(--color-fg-muted); font-size: 0.75rem; max-width: 1200px; margin-left: auto; margin-right: auto; }
  @media (max-width: 768px) { .cols { grid-template-columns: 1fr 1fr; } }
</style>
