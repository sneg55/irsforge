---
interface Props {
  question: string
}
const { question } = Astro.props
---
<details class="faq">
  <summary>
    <span class="q">{question}</span>
    <span class="chev" aria-hidden>+</span>
  </summary>
  <div class="answer"><slot /></div>
</details>

<style>
  .faq { border-bottom: 1px solid var(--color-border); }
  .faq summary {
    padding: 1.25rem 0.75rem;
    margin: 0 -0.75rem;
    cursor: pointer; font-size: 1.0625rem; color: var(--color-fg);
    display: flex; justify-content: space-between; align-items: center;
    list-style: none;
    border-radius: 2px;
    transition: background-color .2s ease, color .2s ease, padding-left .25s ease;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary:hover { background: rgba(201, 169, 97, 0.04); padding-left: 1.1rem; }
  .faq summary:focus-visible {
    outline: 1px solid var(--color-accent);
    outline-offset: 2px;
  }
  .q {
    background-image: linear-gradient(var(--color-accent), var(--color-accent));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    transition: background-size .3s cubic-bezier(.2,.7,.2,1);
  }
  .faq summary:hover .q { background-size: 100% 1px; }
  .chev {
    color: var(--color-accent);
    font-size: 1.25rem;
    transition: transform .3s cubic-bezier(.2,.7,.2,1), color .2s ease;
  }
  .faq[open] summary .chev { transform: rotate(135deg); color: var(--color-fg); }
  .answer {
    padding: 0 0 1.5rem;
    color: var(--color-fg-body);
    font-size: 0.9375rem;
    line-height: 1.65;
  }
  .faq[open] .answer { animation: faq-reveal .3s ease-out both; }
  @keyframes faq-reveal {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .answer :global(p) { margin: 0 0 0.75rem; }
  .answer :global(p:last-child) { margin-bottom: 0; }
</style>
