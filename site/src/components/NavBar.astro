---
---
<header class="navbar">
  <a href="/" class="brand-link" aria-label="IRSForge home">
    <img src="/favicon.svg" alt="" width="40" height="40" class="brand-mark" />
    <span class="wordmark">IRSForge</span>
  </a>
  <nav class="nav-links">
    <a href="https://docs.irsforge.com" class="nav-link">Docs</a>
    <a href="https://github.com/sneg55/irsforge" class="nav-link" rel="noopener">GitHub</a>
    <a href="https://demo.irsforge.com" class="nav-cta">Live Demo</a>
  </nav>
  <span class="scroll-progress" aria-hidden="true"></span>
</header>

<script>
  if (typeof window !== 'undefined') {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const bar = document.querySelector('.scroll-progress') as HTMLElement | null
    if (bar && !reduce) {
      let raf = 0
      const update = () => {
        const h = document.documentElement
        const max = h.scrollHeight - h.clientHeight
        const pct = max > 0 ? (h.scrollTop || window.scrollY) / max : 0
        bar.style.transform = `scaleX(${Math.min(1, Math.max(0, pct))})`
        raf = 0
      }
      const onScroll = () => {
        if (raf) return
        raf = requestAnimationFrame(update)
      }
      window.addEventListener('scroll', onScroll, { passive: true })
      window.addEventListener('resize', onScroll, { passive: true })
      update()
    }
  }
</script>

<style>
  .navbar {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(10, 14, 26, 0.85);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .brand-link {
    display: inline-flex; align-items: center; gap: 0.75rem;
    color: var(--color-fg);
  }
  .brand-link:hover { color: var(--color-fg); }
  .brand-mark {
    border-radius: 4px;
    display: block;
    transition: transform .35s cubic-bezier(.2,.7,.2,1), filter .35s ease;
  }
  .brand-link:hover .brand-mark {
    transform: rotate(-6deg) scale(1.05);
    filter: drop-shadow(0 4px 14px rgba(201, 169, 97, 0.35));
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem; color: var(--color-fg); letter-spacing: 0.02em;
    transition: letter-spacing .25s ease;
  }
  .brand-link:hover .wordmark { letter-spacing: 0.04em; }
  .nav-cta {
    position: relative;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 2px;
    font-size: 0.875rem;
    transition: background-color .2s ease, color .2s ease, transform .2s ease, box-shadow .25s ease;
  }
  .nav-cta:hover {
    background: var(--color-accent); color: var(--color-bg);
    transform: translateY(-1px);
    box-shadow: 0 8px 22px -10px rgba(201, 169, 97, 0.55);
  }
  .nav-cta:active { transform: translateY(0); }
  .nav-links {
    display: flex; align-items: center; gap: 1.5rem;
  }
  .nav-link {
    position: relative;
    color: var(--color-fg-body);
    font-size: 0.875rem;
    font-family: var(--font-body);
    transition: color 0.15s;
  }
  .nav-link::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -4px;
    height: 1px; background: var(--color-accent);
    transform: scaleX(0); transform-origin: left center;
    transition: transform .25s cubic-bezier(.2,.7,.2,1);
  }
  .nav-link:hover { color: var(--color-fg); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link:focus-visible { outline: none; }
  .nav-link:focus-visible::after { transform: scaleX(1); }

  .scroll-progress {
    position: absolute; left: 0; right: 0; bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent-dim), var(--color-accent));
    transform: scaleX(0); transform-origin: left center;
    pointer-events: none;
  }

  @media (max-width: 600px) {
    .nav-links { gap: 1rem; }
    .nav-link { display: none; }
  }
</style>
