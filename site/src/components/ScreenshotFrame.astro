---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt: string
  caption: string
  loading?: 'lazy' | 'eager'
}
const { src, alt, caption, loading = 'lazy' } = Astro.props
---
<figure class="frame">
  <Image src={src} alt={alt} loading={loading} class="img" />
  <figcaption class="caption mono">{caption}</figcaption>
</figure>

<style>
  .frame {
    margin: 0;
    border: 1px solid var(--color-accent-dim);
    border-radius: 6px;
    background: var(--color-bg-elevated);
    box-shadow: inset 0 1px 0 rgba(245, 239, 224, 0.04);
    overflow: hidden;
    transition: transform .4s cubic-bezier(.2,.7,.2,1), box-shadow .4s ease, border-color .3s ease;
    will-change: transform;
  }
  .frame:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: inset 0 1px 0 rgba(245, 239, 224, 0.06), 0 30px 70px -30px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(201, 169, 97, 0.12);
  }
  .img {
    width: 100%; height: auto; display: block;
    transition: transform .6s cubic-bezier(.2,.7,.2,1);
  }
  .frame:hover .img { transform: scale(1.012); }
  .caption {
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }
</style>
